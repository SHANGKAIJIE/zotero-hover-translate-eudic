pref-title = Hover Translate Eudic

pref-section-basic = 基础功能设置
pref-enableHoverTranslate =
    .label = 启用悬停翻译（插件总开关）
pref-triggerMode = 取词触发方式：
pref-triggerMode-hover =
    .label = 鼠标悬停
pref-triggerMode-modifier =
    .label = 修饰键 + 悬停
pref-triggerMode-click =
    .label = 鼠标左键单击
pref-modifierKeys = 修饰键组合：
pref-modifierCtrl =
    .label = Ctrl
pref-modifierAlt =
    .label = Alt
pref-modifierShift =
    .label = Shift
pref-enableHighlight =
    .label = 取词高亮（临时高亮匹配单词，不修改 PDF）
pref-highlightColor = 高亮颜色：
pref-highlightColorR = R:
pref-highlightColorG = G:
pref-highlightColorB = B:
pref-highlightColorA = A:
pref-highlightColorA-unit = %
pref-hoverDelay = 悬停触发延迟：
pref-hoverDelay-unit = 毫秒
pref-popupAutoCloseDelay = 弹窗自动关闭：
pref-popupAutoCloseDelay-unit = 秒（0=不自动关闭）
pref-translateDisplayMode = 翻译显示模式：
pref-translateDisplayMode-simple =
    .label = 简洁（仅译文）
pref-translateDisplayMode-full =
    .label = 完整（译文+字典释义，同 Translate for Zotero）
pref-disableOnSelection =
    .label = 选中文字时禁用悬停（避免与划词翻译冲突）

pref-section-eudic = 欧路词典生词本设置
pref-enableEudicSync =
    .label = 启用生词本同步（翻译弹窗显示「+生词本」按钮）
pref-eudicToken = API Token：
pref-eudicToken-apply = 申请欧路 OpenAPI Token（带 NIS 前缀）
pref-eudicCategory = 选择生词本：
pref-eudicCategory-refresh =
    .label = 刷新列表
pref-eudicCategory-edit =
    .label = 编辑词本
pref-eudicLanguage = 单词语言：
pref-buttonShowScene = 按钮显示场景：
pref-buttonShowScene-both =
    .label = 悬停 + 划词都显示
pref-buttonShowScene-hover =
    .label = 仅悬停翻译显示
pref-buttonShowScene-selection =
    .label = 仅划词翻译显示
pref-addWordMode = 加词方式：
pref-addWordMode-manual =
    .label = 手动点击按钮添加
pref-addWordMode-auto =
    .label = 翻译后自动加入生词本

pref-section-export = 导出生词本
pref-export-format = 导出格式：
pref-export-format-csv =
    .label = CSV（逗号分隔，Excel 可用）
pref-export-format-tsv =
    .label = TSV（制表符分隔，Anki 可用）
pref-export-format-txt =
    .label = TXT（纯文本）
pref-export-format-json =
    .label = JSON（完整数据结构）
pref-export-autoReveal =
    .label = 导出后自动打开文件管理器定位到文件
pref-export-savePath = 保存位置：
pref-export-savePath-placeholder = 留空则保存在 Zotero 配置目录
pref-export-btn =
    .label = 导出

pref-section-other = 其他设置
pref-resetBtn =
    .label = 恢复默认设置
pref-help-link = 使用说明与 Token 申请教程
pref-help = { $name } Build { $version } { $time }
